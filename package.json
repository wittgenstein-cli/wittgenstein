{
  "name": "wittgenstein-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Wittgenstein — a modality harness for text-first LLMs.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "new-adr": "tsx scripts/new-adr.ts",
    "doctor": "pnpm --filter @wittgenstein/cli exec wittgenstein doctor",
    "release:npm-cli": "pnpm --filter @wittgenstein/cli run release:npm",
    "publish:npm-cli": "pnpm run release:npm-cli && npm publish packages/cli/npm-publish",
    "dev:site": "pnpm --filter @wittgenstein-site dev",
    "dev:presentation": "pnpm --filter @wittgenstein/presentation dev",
    "dev:wittgenstein-kimi": "pnpm --filter @wittgenstein/wittgenstein-kimi-deck dev"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.5",
      "@types/react-dom": "^19.2.3"
    }
  },
  "devDependencies": {
    "@wittgenstein/cli": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
